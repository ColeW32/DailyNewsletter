# --- Required to write & send ---

# Anthropic — Claude writes the newsletter copy
ANTHROPIC_API_KEY=

# Resend — sends the email
RESEND_API_KEY=

# For prototyping you can use Resend's built-in test sender (no domain setup needed).
# Note: with the test sender you can only deliver to the email you signed up to Resend with.
NEWSLETTER_FROM="Survey Club <onboarding@resend.dev>"

# Where the prototype sends (your address while testing)
NEWSLETTER_TO=jason@abstrakt.group

# --- Optional ---

# The prototype pulls markets data from Yahoo Finance (no key needed).
# These are only needed if/when we upgrade the Markets Snapshot to a keyed provider.
POLYGON_API_KEY=
FMP_API_KEY=

# --- Subscribe endpoints (deployed separately on Vercel; NOT used by the cron) ---
# See SUBSCRIBE.md. These are set in the Vercel project's env, not here.
# RESEND_AUDIENCE_ID=   # the Resend Audience new subscribers are added to
# SUBSCRIBE_SECRET=     # random string for signing confirm links (openssl rand -hex 32)
# CONFIRM_BASE_URL=     # public base URL of the endpoints, e.g. https://subscribe.getsurvey.club
# ALLOWED_ORIGINS=      # optional CSV of allowed site origins; omit to allow all

# --- Open/click analytics (Vercel functions: /api/resend-webhook + /api/stats) ---
# Set in the Vercel project's env, not here.
# RESEND_WEBHOOK_SIGNING_SECRET=   # whsec_... from the Resend webhook (verifies /api/resend-webhook)
# Upstash Redis store for daily open/click counters. The Vercel Upstash/KV
# integration injects these automatically — add them only for local runs:
# KV_REST_API_URL=                 # or UPSTASH_REDIS_REST_URL
# KV_REST_API_TOKEN=               # or UPSTASH_REDIS_REST_TOKEN
